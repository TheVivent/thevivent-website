<!doctype html>
<html lang="pl">
  <head>
    {{>head}}
  </head>
  <body>
    <header>
			{{>header}}
    </header>

    <article class="container-fluid">
      {{{ body }}}
    </article>


    {{!-- move scripts to separate partial !!! --}}
    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta2/dist/js/bootstrap.bundle.min.js" integrity="sha384-b5kHyXgcpbZJO/tY9Ul7kGkf1S0CWuKcCD38l8YkeH8z8QjE0GmW1gYU5S9FOnJ0" crossorigin="anonymous"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>

    <script>
        $("a").on("click", (event) => {
          event.preventDefault();
          
          console.log(`${event.currentTarget.href}?ajax=true`)

          $.get(`${event.currentTarget.href}?ajax=true`, (data) => {
            $("article.container-fluid").html(data)
            
            window.history.pushState(data,"", event.currentTarget.href);

          })

        })

        window.onpopstate = function(e){
          if(e.state){
            $("article.container-fluid").html(e.state);
            //document.title = e.state.pageTitle;
          }
        };

        $(document).ready(() => {
          window.history.replaceState($("article.container-fluid").html(), "", window.location.href)
        })

    </script>

  </body>
</html>